# Porta do servidor HTTP
PORT=3333

# Ambiente: development | test | production
NODE_ENV=development

# Neon PostgreSQL
# Painel: https://console.neon.tech — copie a connection string (com sslmode=require)
#
# Runtime (pooler — recomendado para a API):
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"
#
# Migrations (host direto — sem -pooler):
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Segredo para assinar os JWT (troque em produção!)
JWT_SECRET="troque-este-segredo-em-producao"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Origem permitida no CORS (frontend). Use "*" só em desenvolvimento.
CORS_ORIGIN="http://localhost:5173"
